# Files to exclude from the source distribution.
# setuptools_scm includes all git-tracked files by default; this prunes back
# to just what's needed to build and install the package.

# Curation scripts and metadata — internal data prep, not for end users
prune datasets

# Bundled assets only used by curation
prune resources

# Dev tooling and project metadata not needed at install time
exclude .gitignore
exclude .pre-commit-config.yaml
exclude CLAUDE.md
exclude uv.lock
prune .github
prune .scratch
